# profile-project environment variables (copy to .env or export in your shell).
# Secrets are ENV-ONLY and are never written to .profile_project_config.json.

# --- Secrets (env-only; modeled as SecretStr; never persisted to disk) ---
PROFILE_PROJECT_OPENAI_API_KEY=
PROFILE_PROJECT_PINECONE_API_KEY=

# --- Embeddings method selector (alias; unset => init prompts) ---
# one of: sentence-transformers | openai | ollama | disabled
PROFILE_PROJECT_DEFAULT_EMBEDDINGS_METHOD=
# nested-form alias for the same field:
# PROFILE_PROJECT_EMBEDDINGS__METHOD=

# --- Vectorstore backend selector (alias; unset => init prompts) ---
# one of: chromadb | pinecone | disabled
PROFILE_PROJECT_VECTORSTORE__BACKEND=
PROFILE_PROJECT_VECTORSTORE__ENABLED=true
PROFILE_PROJECT_VECTORSTORE__COLLECTION=profile-project

# --- ChromaDB (local default) ---
PROFILE_PROJECT_CHROMADB__PATH=.profile_project/chroma

# --- Pinecone (existing index only; never auto-created) ---
PROFILE_PROJECT_PINECONE__INDEX=
PROFILE_PROJECT_PINECONE__NAMESPACE=
PROFILE_PROJECT_PINECONE__EMBEDDINGS_MODEL=

# --- Embeddings models ---
PROFILE_PROJECT_EMBEDDINGS__SENTENCE_TRANSFORMERS__MODEL=all-MiniLM-L6-v2
PROFILE_PROJECT_EMBEDDINGS__OPENAI__MODEL=text-embedding-3-small
PROFILE_PROJECT_EMBEDDINGS__OLLAMA__BASE_URL=http://localhost:11434
PROFILE_PROJECT_EMBEDDINGS__OLLAMA__MODEL=qwen3-embedding:8b

# --- Embed call tuning ---
PROFILE_PROJECT_EMBED_TIMEOUT_SECONDS=30.0
PROFILE_PROJECT_EMBED_MAX_RETRIES=0

# --- DAG phase toggles ---
PROFILE_PROJECT_PHASES__INCLUDE_DOCS=true
PROFILE_PROJECT_PHASES__INCLUDE_TRANSCRIPTS=true
PROFILE_PROJECT_PHASES__BUILD_VECTORSTORE=true

# --- Output directories ---
PROFILE_PROJECT_OUTPUT__CONTEXT_DIR=profile/context
PROFILE_PROJECT_OUTPUT__GUIDE_DIR=profile/guide

# --- Project root override (defaults to cwd discovery) ---
PROFILE_PROJECT_PROJECT_DIR=
